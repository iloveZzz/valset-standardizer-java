<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yss.subjectmatch.extract.repository.mapper.ValuationFileDataMapper">

    <!-- Result Map for ValuationFileDataPO -->
    <resultMap id="BaseResultMap" type="com.yss.subjectmatch.extract.repository.entity.ValuationFileDataPO">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="task_id" property="taskId" jdbcType="BIGINT"/>
        <result column="file_id" property="fileId" jdbcType="BIGINT"/>
        <result column="row_data_number" property="rowDataNumber" jdbcType="INTEGER"/>
        <result column="row_data_json" property="rowDataJson" jdbcType="VARCHAR"/>
    </resultMap>

    <insert id="insert" parameterType="com.yss.subjectmatch.extract.repository.entity.ValuationFileDataPO">
        INSERT INTO t_ods_valuation_filedata (
            id,
            task_id,
            file_id,
            row_data_number,
            row_data_json
        ) VALUES (
            #{id},
            #{taskId},
            #{fileId},
            #{rowDataNumber},
            #{rowDataJson}
        )
    </insert>

    <!-- Find all records by task ID -->
    <select id="findByTaskId" resultMap="BaseResultMap">
        SELECT id, task_id, file_id, row_data_number, row_data_json
        FROM t_ods_valuation_filedata
        WHERE task_id = #{taskId}
        ORDER BY row_data_number ASC
    </select>

    <!-- Find all records by file ID -->
    <select id="findByFileId" resultMap="BaseResultMap">
        SELECT id, task_id, file_id, row_data_number, row_data_json
        FROM t_ods_valuation_filedata
        WHERE file_id = #{fileId}
        ORDER BY row_data_number ASC
    </select>

</mapper>
